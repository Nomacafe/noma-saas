# ============================================================
# NOMA SaaS — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# ─── MODE LOCAL (sans Supabase) ──────────────────────────────
# Mettre true pour utiliser la base JSON locale (data/db.json)
# Mettre false (ou supprimer) pour utiliser Supabase
USE_LOCAL_DB=true

# ─── Supabase (cloud) ────────────────────────────────────────
# Requis uniquement si USE_LOCAL_DB=false
# Récupérer depuis app.supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...votre_anon_key...
# IMPORTANT : utiliser la SERVICE ROLE KEY (pas l'anon key !)
SUPABASE_SERVICE_ROLE_KEY=eyJ...votre_service_role_key...
